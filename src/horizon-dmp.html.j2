{#-
  Horizon Europe Data Management Plan (HTML for pandoc -> DOCX).

  Reproduces the structure of the official Horizon Europe DMP template
  (input/data-management-plan_he_en.docx) and fills each guidance question
  with answers extracted from the Norwegian Generic KM
  (research.data.no:norway-generic:1.2.0+).

  Strategy mirrors src/_mapping.j2:
    - Use the official `extract_replies` filter (DSW >= 4.20): annotation-based
      `json.key` / `json.value` navigation, no UUID references.
    - All access is guarded; unanswered questions render a "(not answered)"
      placeholder so the HE structure stays complete.

  Output: HTML. The Word format (template.json) runs this through pandoc with
  the HE docx as `--reference-doc` so headings (Heading 2 / Heading 3) and the
  body style match the official template.

  Reply shape recap (from extract_replies):
    - ValueQuestion       -> { _value: str }
    - IntegrationQuestion -> { _value: md, _raw: payload }
    - OptionsQuestion     -> { _uuid, _label, _value, ...followUps } | None
    - MultiChoiceQuestion -> [ { _uuid, _label, _value } ]
    - ListQuestion        -> [ { _uuid, ...childQuestions } ]
    - Unanswered          -> None (or [] for list/multichoice with json.key)
-#}
{%- set dc = ctx|to_context_obj -%}
{%- set replies = dc|extract_replies -%}
{%- set admin      = replies.administrativeInformation -%}
{%- set research   = replies.researchProjectChapter -%}
{%- set legal      = replies.legalEthicalAspectsChapter -%}
{%- set storing    = replies.storingProtectingChapter -%}
{%- set reusing    = replies.reusingCollectingChapter -%}
{%- set datadoc    = replies.creatingData -%}
{%- set processing = replies.processingDataChapter -%}
{%- set archiving  = replies.archivingPublishingChapter -%}
{%- set respres    = replies.responsibilitiesResourcesChapter -%}

{#- ---------------- helper macros ---------------- -#}

{#- Display string for a single reply: option/multichoice item -> label,
    value/integration -> value. Anything else -> empty. -#}
{%- macro sval(r) -%}
  {%- if r is mapping -%}
    {%- if r._label is defined and r._label -%}{{ r._label }}
    {%- elif r._value is defined and r._value -%}{{ r._value }}
    {%- endif -%}
  {%- endif -%}
{%- endmacro -%}

{#- One labelled markdown line, emitted only when the reply has content.
    `label` may be empty to emit the bare value. `r` may be a reply mapping
    or a plain string. -#}
{%- macro line(label, r) -%}
  {%- set s = sval(r)|trim if r is mapping else (r|string|trim if r is not none else "") -%}
  {%- if s -%}
{% if label %}**{{ label }}:** {% endif %}{{ s }}{{ "\n\n" }}
  {%- endif -%}
{%- endmacro -%}

{#- Join the labels of a multichoice list (list of option mappings). -#}
{%- macro linemulti(label, lst) -%}
  {%- if lst -%}
    {%- set labels = lst | map(attribute='_label') | select | list -%}
    {%- if labels|length > 0 -%}
{% if label %}**{{ label }}:** {% endif %}{{ labels|join(', ') }}{{ "\n\n" }}
    {%- endif -%}
  {%- endif -%}
{%- endmacro -%}

{#- Render one guidance question: italic prompt + answer (or placeholder). -#}
{%- macro q(prompt, content) -%}
<p class="prompt"><span custom-style="Guidance">{{ prompt }}</span></p>
{%- if content and content|trim -%}
{{ content|markdown }}
{%- else -%}
<p class="answer placeholder"><em>(not answered)</em></p>
{%- endif %}
{%- endmacro -%}

