      "icon": "fas fa-file-code",
      "steps": [
        {
          "name": "jinja",
          "options": {
            "template": "src/horizon-dmp.html.j2",
            "content-type": "text/html",
            "extension": "html"
          }
        }
      ]

    },


    {
      "uuid": "2031f1f2-62a1-425f-aefa-593022e421f8",
      "name": "Word Document (Horizon Europe)",
      "icon": "fas fa-file-word",
      "steps": [
        {
          "name": "jinja",
          "options": {
            "template": "src/horizon-dmp.html.j2",
            "content-type": "text/html",
            "extension": "html"
          }
        },
        {
          "name": "pandoc",
          "options": {
            "from": "html",
