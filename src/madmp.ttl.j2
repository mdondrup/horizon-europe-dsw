{%- import "src/_mapping.j2" as mapping with context -%}
{%- set dmp = mapping.madmp["dmp"] -%}
@prefix dct: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcso: <https://w3id.org/dcso/ns/core#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dcs-lang: <https://w3id.org/dcso/id/iso639-3/> .

{# URI mappings #}
{%- set uri_dmp = dmp["dmp_id"]["identifier"] -%}
{%- set uri_dmpid = uri_dmp ~ "/identifier" -%}

{%- macro make_uri(identifier, type) -%}
  {%- if identifier.startswith("http") -%}
    {{ identifier }}
  {%- elif type == "orcid" -%}
    https://orcid.org/{{ identifier }}
  {%- elif type == "doi" -%}
    https://doi.org/{{ identifier }}
  {%- elif type == "handle" -%}
    https://hdl.handle.net/{{ identifier }}
  {%- else -%}
    {{ uri_dmp }}#{{ identifier }}
  {%- endif -%}
{%- endmacro -%}

# DMP
<{{ uri_dmp }}>
  a dcso:DMP ;
  dct:title {{ dmp["title"]|tojson }} ;
  dct:description {{ dmp["description"]|tojson }} ;
  dct:language dcs-lang:{{ dmp["language"] }} ;
  dcso:ethicalIssuesExist {{ dmp["ethical_issues_exist"]|tojson }} ;
{%- if "ethical_issues_description" in dmp.keys() %}
  dcso:ethicalIssuesDescription {{ dmp["ethical_issues_description"]|tojson }} ;
{%- endif %}
  dcso:hasDMPId <{{ uri_dmpid }}> ;
{%- if "contact" in dmp.keys() %}
  dcso:hasContact <{{ make_uri(dmp["contact"]["contact_id"]["identifier"], dmp["contact"]["contact_id"]["type"]) }}> ;
{%- endif %}
{%- if "contributor" in dmp.keys() and dmp["contributor"]|length > 0 %}
  dcso:hasContributor
  {%- for contributor in dmp["contributor"] %}
    [ a dcso:Contributor ;
      dcso:hasContributorId
        [ a dcso:ContributorId ;
          dcso:identifier_type {{ contributor["contributor_id"]["type"]|tojson }} ;
          dct:identifier {{ contributor["contributor_id"]["identifier"]|tojson }} ;
        ] ;
      {%- if "mbox" in contributor.keys() %}
      foaf:mbox {{ contributor["mbox"]|tojson }} ;
      {%- endif %}
      {%- if contributor["role"]|length > 0 %}
      dcso:role {{ contributor["role"]|map('tojson')|join(', ') }} ;
      {%- endif %}
      {%- if "affiliation" in contributor.keys() and contributor["affiliation"]|length > 0 %}
      {%- for aff in contributor["affiliation"] %}
      dcso:hasAffiliation
        [ a dcso:Affiliation ;
          foaf:name {{ aff["name"]|tojson }} ;
          {%- if "affiliation_id" in aff.keys() %}
          dcso:hasAffiliationId
            [ a dcso:AffiliationId ;
              dcso:identifier_type {{ aff["affiliation_id"]["type"]|tojson }} ;
              dct:identifier {{ aff["affiliation_id"]["identifier"]|tojson }} ;
            ] ;
          {%- endif -%}
        ] ;
      {%- endfor %}
      {%- endif %}
      foaf:name {{ contributor["name"]|tojson }} ;
    ] {{ ";" if loop.last else "," }}
  {%- endfor -%}
{%- endif %}
{%- if "project" in dmp.keys() and dmp["project"]|length > 0 %}
  dcso:hasProject
  {%- for project in dmp["project"] %}
    [ a dcso:Project ;
      dct:title {{ project["title"]|tojson }} ;
      {%- if "description" in project.keys() %}
      dct:description {{ project["description"]|tojson }} ;
      {%- endif %}
      {%- if "start" in project.keys() %}
      dcso:start {{ project["start"]|tojson }}^^xsd:date ;
      {%- endif %}
      {%- if "end" in project.keys() %}
      dcso:end {{ project["end"]|tojson }}^^xsd:date ;
      {%- endif %}
      {%- if "funding" in project.keys() and project["funding"]|length > 0 %}
      dcso:hasFunding
      {%- for funding in project["funding"] %}
        [ a dcso:Funding ;
          dcso:hasFunderId
            [ a dcso:FunderId ;
              dcso:identifier_type {{ funding["funder_id"]["type"]|tojson }} ;
              dct:identifier {{ funding["funder_id"]["identifier"]|tojson }} ;
            ] ;
          {%- if "funding_status" in funding.keys() %}
          dcso:fundingStatus {{ funding["funding_status"]|tojson }} ;
          {%- endif %}
          {%- if "grant_id" in funding.keys() %}
          dcso:hasGrantId
            [ a dcso:GrantId ;
              dcso:identifier_type {{ funding["grant_id"]["type"]|tojson }} ;
              dct:identifier {{ funding["grant_id"]["identifier"]|tojson }} ;
            ] ;
          {%- endif -%}
        ] {{ ";" if loop.last else "," }}
      {%- endfor -%}
      {%- endif %}
    ] {{ ";" if loop.last else "," }}
  {%- endfor -%}
{%- endif %}
{#- ---------------- Datasets (DCSO core + DCAT) ----------------
     dcat: = byteSize/downloadURL/accessURL (DCAT terms, not DCSO).
     DCSO core has no AlternateIdentifier (alternates -> extra hasDatasetId)
     and no HostId (host.host_id is not emitted). -#}
{%- if "dataset" in dmp.keys() and dmp["dataset"]|length > 0 %}
  dcso:hasDataset
  {%- for dataset in dmp["dataset"] %}
    [ a dcso:Dataset ;
      dcso:hasDatasetId
        [ a dcso:DatasetId ;
          dcso:identifier_type {{ dataset["dataset_id"]["type"]|tojson }} ;
          dct:identifier {{ dataset["dataset_id"]["identifier"]|tojson }} ;
        ] ;
      {%- if "alternate_identifier" in dataset.keys() and dataset["alternate_identifier"]|length > 0 %}
      {#- DCSO core has no AlternateIdentifier class; represent each as an extra DatasetId. -#}
      {%- for alt in dataset["alternate_identifier"] %}
      dcso:hasDatasetId
        [ a dcso:DatasetId ;
          dcso:identifier_type {{ alt["type"]|tojson }} ;
          dct:identifier {{ alt["identifier"]|tojson }} ;
        ] ;
      {%- endfor %}
      {%- endif %}
      dct:title {{ dataset["title"]|tojson }} ;
      {%- if "description" in dataset.keys() %}
      dct:description {{ dataset["description"]|tojson }} ;
      {%- endif %}
      {%- if "type" in dataset.keys() %}
      dct:type {{ dataset["type"]|tojson }} ;
      {%- endif %}
      {%- if "is_reused" in dataset.keys() %}
      dcso:isReused {{ dataset["is_reused"]|tojson }} ;
      {%- endif %}
      {%- if "preservation_statement" in dataset.keys() %}
      dcso:preservationStatement {{ dataset["preservation_statement"]|tojson }} ;
      {%- endif %}
      {%- if "rights" in dataset.keys() %}
      dct:rights {{ dataset["rights"]|tojson }} ;
      {%- endif %}
      {%- if "technical_resource" in dataset.keys() and dataset["technical_resource"]|length > 0 %}
      dcso:hasTechnicalResource
      {%- for tr in dataset["technical_resource"] %}
        [ a dcso:TechnicalResource ;
          dct:title {{ tr["name"]|tojson }} ;
          {%- if "description" in tr.keys() %}
          dct:description {{ tr["description"]|tojson }} ;
          {%- endif -%}
        ] {{ ";" if loop.last else "," }}
      {%- endfor -%}
      {%- endif %}
      dcso:personalData {{ dataset["personal_data"]|tojson }} ;
      dcso:sensitiveData {{ dataset["sensitive_data"]|tojson }} ;
      {%- if "data_quality_assurance" in dataset.keys() and dataset["data_quality_assurance"]|length > 0 %}
      {%- for qa in dataset["data_quality_assurance"] %}
      dcso:dataQualityAssurance {{ qa|tojson }} ;
      {%- endfor %}
      {%- endif %}
      {%- if "metadata" in dataset.keys() and dataset["metadata"]|length > 0 %}
      dcso:hasMetadata
      {%- for md in dataset["metadata"] %}
        [ a dcso:Metadata ;
          dcso:hasMetadataStandardId
            [ a dcso:MetadataStandardId ;
              dcso:identifier_type {{ md["metadata_standard_id"]["type"]|tojson }} ;
              dct:identifier {{ md["metadata_standard_id"]["identifier"]|tojson }} ;
            ] ;
          {%- if "description" in md.keys() %}
          dct:description {{ md["description"]|tojson }} ;
          {%- endif %}
          {%- if "language" in md.keys() %}
          dcso:language {{ md["language"]|tojson }} ;
          {%- endif -%}
        ] {{ ";" if loop.last else "," }}
      {%- endfor -%}
      {%- endif %}
      {%- if "distribution" in dataset.keys() and dataset["distribution"]|length > 0 %}
      dcso:hasDistribution
      {%- for distribution in dataset["distribution"] %}
        [ a dcso:Distribution ;
          dct:title {{ distribution["title"]|tojson }} ;
          {%- if "data_access" in distribution.keys() %}
          dcso:dataAccess {{ distribution["data_access"]|tojson }} ;
          {%- endif %}
          {%- if "format" in distribution.keys() and distribution["format"]|length > 0 %}
          {%- for fmt in distribution["format"] %}
          dct:format {{ fmt|tojson }} ;
          {%- endfor %}
          {%- endif %}
          {%- if "byte_size" in distribution.keys() %}
          dcat:byteSize {{ distribution["byte_size"] }} ;
          {%- endif %}
          {%- if "download_url" in distribution.keys() %}
          dcat:downloadURL <{{ distribution["download_url"] }}> ;
          {%- endif %}
          {%- if "access_url" in distribution.keys() %}
          dcat:accessURL <{{ distribution["access_url"] }}> ;
          {%- endif %}
          {%- if "host" in distribution.keys() %}
          dcso:hasHost
            [ a dcso:Host ;
              {%- if "title" in distribution["host"].keys() %}
              dct:title {{ distribution["host"]["title"]|tojson }} ;
              {%- endif %}
              {%- if "url" in distribution["host"].keys() %}
              dcso:url <{{ distribution["host"]["url"] }}> ;
              {%- endif %}
              {%- if "description" in distribution["host"].keys() %}
              dct:description {{ distribution["host"]["description"]|tojson }} ;
              {%- endif %}
              {%- if "pid_system" in distribution["host"].keys() %}
              {%- for ps in distribution["host"]["pid_system"] %}
              dcso:pidSystem {{ ps|tojson }} ;
              {%- endfor %}
              {%- endif -%}
              {#- host.host_id is not representable in DCSO core (no HostId class). -#}
            ] ;
          {%- endif %}
          {%- if "license" in distribution.keys() and distribution["license"]|length > 0 %}
          dcso:hasLicense
          {%- for license in distribution["license"] %}
            [ a dcso:License ;
              dcso:licenseRef {{ license["license_ref"]|tojson }} ;
              dcso:startDate {{ license["start_date"]|tojson }}^^xsd:date ;
            ] {{ ";" if loop.last else "," }}
          {%- endfor -%}
          {%- endif %}
        ] {{ ";" if loop.last else "," }}
      {%- endfor -%}
      {%- endif %}
    ] {{ ";" if loop.last else "," }}
  {%- endfor -%}
{%- endif %}
{%- if "cost" in dmp.keys() and dmp["cost"]|length > 0 %}
  dcso:hasCost
  {%- for cost in dmp["cost"] %}
    [ a dcso:Cost ;
      {%- if "value" in cost.keys() %}
      dcso:value {{ cost["value"]|tojson }} ;
      {%- endif -%}
      {%- if "currency_code" in cost.keys() %}
      dcso:currency_code {{ cost["currency_code"]|tojson  }} ;
      {%- endif -%}
      {%- if "description" in cost.keys() %}
      dct:description {{ cost["description"]|tojson }} ;
      {%- endif %}
      dct:title {{ cost["title"]|tojson }} ;
    ] {{ ";" if loop.last else "," }}
  {%- endfor -%}
{%- endif %}
  dct:created "{{ dmp["created"] }}"^^xsd:dateTime ;
  dct:modified "{{ dmp["modified"] }}"^^xsd:dateTime .

# DMP identifier
<{{ uri_dmpid }}> 
  a dcso:DMPId ;
  dcso:identifier_type {{ dmp["dmp_id"]["type"]|tojson }} ;
  dct:identifier {{ dmp["dmp_id"]["identifier"]|tojson }} .

# DMP contact
{%- if "contact" in dmp.keys() %}
{%- set uri_contact = make_uri(dmp["contact"]["contact_id"]["identifier"], dmp["contact"]["contact_id"]["type"]) %}
{%- set uri_contact_id = uri_contact ~ "/identifier" %}
<{{ uri_contact }}> a dcso:Contact ;
  dcso:hasContactId <{{ uri_contact_id }}> ;
  foaf:mbox {{ dmp["contact"]["mbox"]|tojson }} ;
  foaf:name {{ dmp["contact"]["name"]|tojson }} .

<{{ uri_contact_id }}> a dcso:ContactId ;
  dcso:identifier_type {{ dmp["contact"]["contact_id"]["type"]|tojson }} ;
  dct:identifier {{ dmp["contact"]["contact_id"]["identifier"]|tojson }} .
{%- endif %}


