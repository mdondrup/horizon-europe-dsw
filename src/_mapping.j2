{#-
  maDMP mapping for the Norwegian Generic KM (research.data.no_norway-generic_1.2.0+).

  Strategy:
    - Use the official `extract_replies` filter (DSW >= 4.20). It walks the KM
      using `json.key` / `json.value` annotations and returns a nested object
      whose keys are stable, human-readable identifiers.
    - No direct UUID references. Every navigation is by annotation key.
    - Required members are accessed directly; missing required data => render
      failure (fail-fast). Optional members are guarded with `if`.

  Reply shape recap (from extract_replies):
    - ValueQuestion       -> { _value: str, _path }
    - IntegrationQuestion -> { _value: md, _raw: payload, _path } (or _raw absent if plain)
    - OptionsQuestion     -> { _uuid, _label, _value, _path, ...followUps } | None
    - MultiChoiceQuestion -> [ { _uuid, _label, _value, _path } ]
    - ListQuestion        -> [ { _uuid, _path, ...childQuestions } ]
    - Unanswered          -> None (or [] for list/multichoice with json.key)
-#}
{%- set dc = ctx|to_context_obj -%}
{%- set replies = dc|extract_replies -%}
{%- set admin     = replies.administrativeInformation -%}
{%- set research  = replies.researchProjectChapter -%}
{%- set legal     = replies.legalEthicalAspectsChapter -%}
{%- set archiving = replies.archivingPublishingChapter -%}
{%- set respres   = replies.responsibilitiesResourcesChapter -%}

{#- ---------------- DMP-level metadata ---------------- -#}
{%- set madmpDescription = "This maDMP has been created using "
    ~ dc.config.service_name ~ " (" ~ dc.config.service_domain_name
    ~ ") and is based on knowledge model " ~ dc.pkg.name
    ~ " (" ~ [dc.pkg.organization_id, dc.pkg.km_id, dc.pkg.version]|join(":")
    ~ "). The questionnaire used for this DMP is identified by UUID \""
    ~ ctx.project.uuid ~ "\" within " ~ ctx.config.clientUrl
    ~ " " ~ dc.config.service_name_short ~ " instance." -%}

{%- set madmpDmpId = {
  "identifier": ctx.config.clientUrl ~ "/projects/" ~ ctx.project.uuid,
  "type": "url"
} -%}

{#- ---------------- Contributors & contact ---------------- -#}
{#-
  KM choice json.value -> maDMP role string (lowercase free-text per RDA examples).
-#}
{%- set roleLabelMap = {
  "contactPerson":     "contact person",
  "projectLeader":     "project leader",
  "supervisor":        "supervisor",
  "dataCollector":     "data collector",
  "dataCurator":       "data curator",
  "dataManagerData":   "data manager",
  "projectManager":    "project manager",
  "projectMember":     "project member",
  "workPackageLeader": "work package leader",
  "other":             "other",
} -%}

{%- set contributors = [] -%}
{%- set contacts = [] -%}
{%- for c in admin.contributors -%}
  {#- Required for a usable contributor entry: name + at least one role. -#}
  {%- set name = c.name._value if c.name else "" -%}
  {%- set email = c.email._value if c.email else "" -%}
  {%- set roleValues = c.roles|map(attribute='_value')|list -%}
  {%- set roles = [] -%}
  {%- for rv in roleValues -%}
    {%- do roles.append(roleLabelMap.get(rv, rv)) -%}
  {%- endfor -%}

  {%- set contributorId = {} -%}
  {%- if c.orcid and c.orcid._raw and c.orcid._raw["orcid-id"] -%}
    {%- set contributorId = {
      "identifier": "https://orcid.org/" ~ c.orcid._raw["orcid-id"],
      "type": "orcid"
    } -%}
  {%- else -%}
    {%- set contributorId = {"identifier": c._uuid, "type": "other"} -%}
  {%- endif -%}

  {%- if name and roles|length > 0 -%}
    {%- set entry = {
      "name": name,
      "role": roles|sort,
      "contributor_id": contributorId
    } -%}
    {%- if email -%}{%- do entry.update({"mbox": email}) -%}{%- endif -%}
    {%- do contributors.append(entry) -%}
    {%- if "contactPerson" in roleValues and email -%}
      {%- do contacts.append(entry) -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{#- ---------------- Project (single) & funding ---------------- -#}
{%- set fundings = [] -%}
{%- if research.didPlanApply and research.didPlanApply._value == "yes" -%}
  {%- for f in research.didPlanApply.fundings -%}
    {%- set funderUrl = "" -%}
    {%- if f.funder and f.funder._raw and f.funder._raw.uri -%}
      {%- set funderUrl = f.funder._raw.uri -%}
    {%- elif f.funder and f.funder._value -%}
      {%- set funderUrl = f.funder._value -%}
    {%- endif -%}

    {%- set statusMap = {
      "plannedYetSubmitted": "planned",
      "appliedAwaitingResponse": "applied",
      "granted": "granted",
      "rejected": "rejected"
    } -%}
    {%- set fundingStatus = statusMap.get(f.status._value, "") if f.status else "" -%}
    {%- set grantNumber = f.grantNumber._value if f.grantNumber else "" -%}

    {%- if funderUrl -%}
      {%- set entry = {
        "funder_id": {"identifier": funderUrl, "type": "url"}
      } -%}
      {%- if fundingStatus -%}{%- do entry.update({"funding_status": fundingStatus}) -%}{%- endif -%}
      {%- if grantNumber -%}
        {%- do entry.update({"grant_id": {"identifier": grantNumber, "type": "other"}}) -%}
      {%- endif -%}
      {%- do fundings.append(entry) -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- set projectAbstract = "" -%}
{%- if research.abstract -%}
  {%- if research.abstract._value == "enterTextualProject" and research.abstract.enterAbstractDescription -%}
    {%- set projectAbstract = research.abstract.enterAbstractDescription.markdown_plain} -%}
  {%- elif research.abstract._value == "linkProjectProposal" and research.abstract.linkExternalInformation -%}
    {%- set projectAbstract = research.abstract.linkExternalInformation._value -%}
  {%- endif -%}
{%- endif -%}

{%- set projects = [] -%}
{%- set projectName  = (research.name._value if research.name else "") or ctx.project.name -%}
{%- set projectStart = research.startDate._value if research.startDate else "" -%}
{%- set projectEnd   = research.endDate._value if research.endDate else "" -%}
{%- if projectName -%}
  {%- set project = {"title": projectName} -%}
  {%- if projectStart -%}{%- do project.update({"start": projectStart}) -%}{%- endif -%}
  {%- if projectEnd   -%}{%- do project.update({"end": projectEnd}) -%}{%- endif -%}
  {%- if projectAbstract -%}{%- do project.update({"description": projectAbstract}) -%}{%- endif -%}
  {%- if fundings|length > 0 -%}{%- do project.update({"funding": fundings}) -%}{%- endif -%}
  {%- do projects.append(project) -%}
{%- endif -%}

{#- ---------------- Ethical issues ---------------- -#}
{#-
  YesNoQuestion answers come through as native booleans (True / False).
  OptionsQuestion answers come through as the option's json.value string.
-#}
{%- set ethicalIssues = [] -%}
{%- set ethicalDesc = [] -%}

{%- if legal.requiresEthicalApproval and legal.requiresEthicalApproval._value is sameas true -%}
  {%- do ethicalIssues.append("ethical-approval") -%}
  {%- do ethicalDesc.append("The project requires ethical pre-approval.") -%}
{%- endif -%}

{%- if legal.personalCollectedProcessed -%}
  {%- set pcp = legal.personalCollectedProcessed -%}
  {%- set pcpVal = pcp._value -%}
  {%- if pcpVal in ("yes", "uncertain") -%}
    {%- do ethicalIssues.append("personal-data") -%}
    {%- if pcpVal == "yes" -%}
      {%- do ethicalDesc.append("Personal data will be collected or processed.") -%}
    {%- else -%}
      {%- do ethicalDesc.append("It is uncertain whether personal data will be collected or processed.") -%}
    {%- endif -%}
    {%- if pcp.brieflyDescribePersonal and pcp.brieflyDescribePersonal._value -%}
      {%- do ethicalDesc.append("Personal data: " ~ pcp.brieflyDescribePersonal._value) -%}
    {%- endif -%}
    {%- if pcp.documentParticipantsInformation and pcp.documentParticipantsInformation._value -%}
      {%- do ethicalDesc.append("Participant information: " ~ pcp.documentParticipantsInformation._value) -%}
    {%- endif -%}
  {%- endif -%}
{%- endif -%}

{%- if legal.sensitiveInformationThan -%}
  {%- set sit = legal.sensitiveInformationThan -%}
  {%- set sitVal = sit._value -%}
  {%- if sitVal in ("yes", "uncertain") -%}
    {%- do ethicalIssues.append("sensitive-information") -%}
    {%- if sitVal == "yes" -%}
      {%- do ethicalDesc.append("The project handles sensitive information beyond GDPR special categories.") -%}
    {%- else -%}
      {%- do ethicalDesc.append("It is uncertain whether the project handles sensitive information beyond GDPR special categories.") -%}
    {%- endif -%}
    {%- if sit.brieflyDescribeSensitive and sit.brieflyDescribeSensitive._value -%}
      {%- do ethicalDesc.append("Sensitive information: " ~ sit.brieflyDescribeSensitive._value) -%}
    {%- endif -%}
    {%- if sit.applicableLegalEthical and sit.applicableLegalEthical._value -%}
      {%- do ethicalDesc.append("Applicable legal/ethical framework: " ~ sit.applicableLegalEthical._value) -%}
    {%- endif -%}
  {%- endif -%}
{%- endif -%}

{%- set ethicalIssuesExist = "yes" if ethicalIssues|length > 0 else "no" -%}
{%- set ethicalIssuesDescription = ethicalDesc|join(" ") -%}

{#- ---------------- Datasets (RDA maDMP Common Standard 1.2) ----------------
     json.key navigation only; runtime UUIDs are list-item _uuid and
     ItemSelect _value references (resolved at runtime). -#}

{%- set licenseRefMap = {
  "freeOpen":            "https://creativecommons.org/publicdomain/zero/1.0/",
  "freeOpenAttribution": "https://creativecommons.org/licenses/by/4.0/",
} -%}
{%- set accessMap = {
  "open":   "open",
  "shared": "shared",
  "closed": "closed",
} -%}

{#- Chapters that hold cross-referenced source lists (aliased for readability). -#}
{%- set reusing = replies.reusingCollectingChapter -%}
{%- set datadoc = replies.creatingData -%}

{%- set datasets = [] -%}
}

{%- for ds in archiving.distributions -%}
  {%- set dsTitle = ds.dataset._value if ds.dataset else "(unnamed dataset)" -%}

  {#- ---------- dataset_id + alternate_identifier (three PID sources) ---------- -#}
  {#- a) Import DOI information from DataCite (DataverseNO, Zenodo, …)
       b) Import information from OMICS DI (biomolecular datasets)
       c) Enter link/reference manually                                          -#}
  {%- set dsId = {"identifier": ds._uuid, "type": "other"} -%}   {#- fallback only -#}
  {%- set altIds = [] -%}
  {%- if ds.hasBeenArchived and ds.hasBeenArchived._value == "trustworthyResearchData" -%}
    {%- set epi = ds.hasBeenArchived.enterPersistentIdentifier -%}
    {%- if epi -%}

      {#- (a) DataCite DOI -#}
      {%- if epi._value == "importDoiInformation" and epi.doiSearch2 and epi.doiSearch2._raw -%}
        {%- set dc = epi.doiSearch2._raw -%}
        {#- DataCite REST exposes the DOI as `id` (and/or attributes.doi), not a bare `doi`. -#}
        {%- set doiId = dc.id if dc.id else (dc.attributes.doi if dc.attributes else None) -%}
        {%- if doiId -%}
          {%- set doiUrl = doiId if doiId.startswith("http") else ("https://doi.org/" ~ doiId) -%}
          {%- set dsId = {"identifier": doiUrl, "type": "doi"} -%}
        {%- endif -%}

      {#- (b) OMICS DI -#}
      {%- elif epi._value == "importInformationOmics" and epi.omicsDiSearch and epi.omicsDiSearch._raw -%}
        {%- set omics = epi.omicsDiSearch._raw -%}
        {%- if omics.id and omics.source -%}
          {%- set dsId = {
            "identifier": "https://www.omicsdi.org/dataset/" ~ omics.source ~ "/" ~ omics.id,
            "type": "url"
          } -%}
          {#- keep the bare accession as an alternate identifier (1.2 field) -#}
          {%- do altIds.append({"identifier": omics.id, "type": "accession number"}) -%}
        {%- endif -%}

      {#- (c) Manual link / reference -#}
      {%- elif epi._value == "enterLinkReference" and epi.linkReference and epi.linkReference._value -%}
        {%- set linkVal = epi.linkReference._value -%}
        {%- set dsId = {"identifier": linkVal,
                        "type": "doi" if "doi.org" in linkVal else "url"} -%}
      {%- endif -%}
    {%- endif -%}
  {%- endif -%}

  {#- ---------- description + data_quality_assurance ----------
       description : free-text branch OR cross-ref ("selectInformationChapter") into a
                     capture-method origin item selected by an ItemSelect question.
       data_quality_assurance : emitted ONLY from a cross-referenced origin item that
                     actually carries a quality field — never from the project-wide
                     Processing chapter:
                       reusingCollectingDataset  -> dataMeasurementEquipment.qualityProcessesApplied (multichoice)
                       reusingCollectingDataset2 -> datasets.integrityQualityMeasures (free text; list under hasNonMeasuredData)
                       reusingCollectingDataset3 -> listPublishedArchived                         (no quality field => no QA)
  -#}
  {%- set dsDescription = "" -%}
  {%- set qa = [] -%}
  {%- if ds.description -%}
    {%- if ds.description._value == "enterFreeText" and ds.description.briefDescriptionDataset -%}
      {%- set dsDescription = ds.description.briefDescriptionDataset._value -%}

    {%- elif ds.description._value == "selectInformationChapter" -%}

      {#- (1) measured data -> dataMeasurementEquipment (quality: qualityProcessesApplied) -#}
      {%- if ds.description.reusingCollectingDataset and reusing and reusing.hasMeasuredData -%}
        {%- set ref = ds.description.reusingCollectingDataset._uuid -%}
        {%- set lst = reusing.hasMeasuredData.dataMeasurementEquipment -%}
        {%- set item = (lst | selectattr('_uuid', 'equalto', ref) | first | default(None))
             if (lst and ref) else None -%}
        {%- if item -%}
          {%- if not dsDescription and item.applicableAdditionalDescription2 and item.applicableAdditionalDescription2._value -%}
            {%- set dsDescription = item.applicableAdditionalDescription2._value -%}
          {%- elif not dsDescription and item.dataset and item.dataset._value -%}
            {%- set dsDescription = "Data originating from: " ~ item.dataset._value -%}
          {%- endif -%}
          {%- if item.qualityProcessesApplied -%}
            {%- for qp in item.qualityProcessesApplied -%}{%- do qa.append(qp._label) -%}{%- endfor -%}
          {%- endif -%}
        {%- endif -%}
      {%- endif -%}

      {#- (2) reused datasets/records -> datasets (quality: integrityQualityMeasures) -#}
      {%- if ds.description.reusingCollectingDataset2 and reusing and reusing.hasNonMeasuredData -%}
        {%- set ref = ds.description.reusingCollectingDataset2._uuid -%}
        {%- set lst = reusing.hasNonMeasuredData.datasets -%}
        {%- set item = (lst | selectattr('_uuid', 'equalto', ref) | first | default(None))
             if (lst and ref) else None -%}
        {%- if item -%}
          {%- if not dsDescription and item.collectionMethodology and item.collectionMethodology._value -%}
            {%- set dsDescription = item.collectionMethodology._value -%}
          {%- elif not dsDescription and item.dataset_1 and item.dataset_1._value -%}
            {%- set dsDescription = "Data originating from: " ~ item.dataset_1._value -%}
          {%- endif -%}
          {%- if item.integrityQualityMeasures and item.integrityQualityMeasures._value -%}
            {%- do qa.append(item.integrityQualityMeasures._value) -%}
          {%- endif -%}
        {%- endif -%}
      {%- endif -%}

      {#- (3) published/archived data -> listPublishedArchived: description only, no quality field.
           TODO: confirm the parent option-question navigation for this list, then read
           descriptionData for the dataset description. No QA is emitted for this branch. -#}
    {%- endif -%}
  {%- endif -%}

  {#- ---------- metadata (cross-ref to the selected metadata standard) ---------- -#}
  {%- set metadataStd = [] -%}
  {%- if ds.metadataAccompaniesDataset -%}
    {%- if ds.metadataAccompaniesDataset._value == "selectAnswerMetadata"
           and ds.metadataAccompaniesDataset.selectMetadataStandard -%}
      {%- set stdRef = ds.metadataAccompaniesDataset.selectMetadataStandard._uuid -%}
      {%- set stdList = datadoc.miaStandardsExist.standards
           if (datadoc and datadoc.miaStandardsExist) else None -%}
      {%- set stdItem = (stdList | selectattr('_uuid', 'equalto', stdRef) | first | default(None))
           if (stdList and stdRef) else None -%}
      {%- if stdItem and stdItem.standard and stdItem.standard._raw and stdItem.standard._raw.doi -%}
        {%- set std = stdItem.standard._raw -%}
        {%- set mEntry = {
          "metadata_standard_id": {"identifier": "https://doi.org/" ~ std.doi, "type": "url"}
        } -%}
        {%- set mDesc = stdItem.provideContextStandard._value
             if (stdItem.provideContextStandard and stdItem.provideContextStandard._value) else std.name -%}
        {%- if mDesc -%}{%- do mEntry.update({"description": mDesc}) -%}{%- endif -%}
        {%- do metadataStd.append(mEntry) -%}
      {%- endif -%}
    {#- TODO: handle 'metadataStandardInformation' (in-dataset FAIRsharing import)
         and 'addMetadataInformation' (manual) with the same metadata shape. -#}
    {%- endif -%}
  {%- endif -%}

  {#- ---------- distribution: access + license ---------- -#}
  {%- set accessVal = accessMap.get(ds.access._value, "") if ds.access else "" -%}

  {%- set licenses = [] -%}
  {%- if ds.licenseDataset -%}
    {%- set ldv = ds.licenseDataset._value -%}
    {%- set licenseRef = "" -%}
    {%- set licenseStart = "" -%}
    {%- if ldv in licenseRefMap -%}
      {%- set licenseRef = licenseRefMap[ldv] -%}
      {%- if ldv == "freeOpen" and ds.licenseDataset.startingDateLicense -%}
        {%- set licenseStart = ds.licenseDataset.startingDateLicense._value -%}
      {%- elif ldv == "freeOpenAttribution" and ds.licenseDataset.startingDateLicense2 -%}
        {%- set licenseStart = ds.licenseDataset.startingDateLicense2._value -%}
      {%- endif -%}
    {%- elif ldv == "restrictions" and ds.licenseDataset.licenseUrl -%}
      {%- set licenseRef = ds.licenseDataset.licenseUrl._value -%}
      {%- if ds.licenseDataset.startingDateLicense3 -%}
        {%- set licenseStart = ds.licenseDataset.startingDateLicense3._value -%}
      {%- endif -%}
    {%- elif ldv == "dataAvailableUnder" and ds.licenseDataset.license -%}
      {%- if ds.licenseDataset.license._raw and ds.licenseDataset.license._raw.uri -%}
        {%- set licenseRef = ds.licenseDataset.license._raw.uri -%}
      {%- elif ds.licenseDataset.license._value -%}
        {%- set licenseRef = ds.licenseDataset.license._value -%}
      {%- endif -%}
    {%- endif -%}
    {%- if licenseRef and licenseStart -%}
      {%- do licenses.append({"license_ref": licenseRef, "start_date": licenseStart}) -%}
    {%- endif -%}
  {%- endif -%}

  {%- set distribution = {"title": dsTitle} -%}
  {%- if accessVal -%}{%- do distribution.update({"data_access": accessVal}) -%}{%- endif -%}
  {%- if ds.fileFormatDataset and ds.fileFormatDataset._value -%}
    {%- do distribution.update({"format": [ds.fileFormatDataset.markdown_plain]}) -%}
  {%- endif -%}

  {#- byte_size: the questionnaire captures size in GB (question text: "…in GB").
       RDA byte_size is an INTEGER number of bytes. Convert (decimal GB = 1e9).
       Use 1073741824 instead if your users mean binary GiB. -#}
  {%- if ds.sizeDataset and ds.sizeDataset._value -%}
    {%- do distribution.update({"byte_size": (ds.sizeDataset._value | float * 1000000000) | int}) -%}
  {%- endif -%}

  {#- download_url: the resolved PID landing/URL, when it is an http(s) URL.
       (access_url is the more precise field for a pure landing page if preferred.) -#}
  {%- if dsId.identifier and dsId.identifier.startswith("http") -%}
    {%- do distribution.update({"download_url": dsId.identifier}) -%}
  {%- endif -%}

  {#- host: built from whichever "Name of the archive" (nameArchive) branch is filled:
       selectAnswerIdentify       -> selectArchive (ItemSelect) -> identifyArchiveDepositing
                                     item's repository (FAIRsharing payload)
       archiveInformationImported -> archiveInformationFairsharing (in-place FAIRsharing payload)
       enterArchiveManually       -> archive (free-text archive name only)
       Both FAIRsharing payloads share the same raw shape (name / homepage / url=DOI).
       TODO (RCN / Science Europe extension): selectArchive is a "Desirable: Complete DMP
       (concluding the project)" stage question; the block is fully guarded and emits no
       host when nothing is filled. -#}
  {%- set na = ds.hasBeenArchived.nameArchive if ds.hasBeenArchived else None -%}
  {%- set repo = None -%}        {#- FAIRsharing raw payload, if any -#}
  {%- set hostTitle = None -%}   {#- plain archive name, manual branch -#}
  {%- if na -%}
    {%- if na._value == "selectAnswerIdentify" and na.selectArchive and na.selectArchive._uuid -%}
      {%- set archiveList = archiving.identifyArchiveDepositing -%}
      {%- set chosen = (archiveList | selectattr('_uuid', 'equalto', na.selectArchive._uuid) | first | default(None))
           if archiveList else None -%}
      {%- if chosen and chosen.repository and chosen.repository._raw -%}
        {%- set repo = chosen.repository._raw -%}
      {%- endif -%}
    {%- elif na._value == "archiveInformationImported"
             and na.archiveInformationFairsharing and na.archiveInformationFairsharing._raw -%}
      {%- set repo = na.archiveInformationFairsharing._raw -%}
    {%- elif na._value == "enterArchiveManually" and na.archive and na.archive._value -%}
      {%- set hostTitle = na.archive._value -%}
    {%- endif -%}
  {%- endif -%}
  {%- set host = {} -%}
  {%- if repo -%}
    {%- if repo.name -%}{%- do host.update({"title": repo.name}) -%}{%- endif -%}
    {%- if repo.homepage -%}{%- do host.update({"url": repo.homepage}) -%}{%- endif -%}
    {%- if repo.url -%}{%- do host.update({"host_id": {"identifier": repo.url, "type": "url"}}) -%}{%- endif -%}
  {%- elif hostTitle -%}
    {%- do host.update({"title": hostTitle}) -%}
  {%- endif -%}
  {%- if host -%}{%- do distribution.update({"host": host}) -%}{%- endif -%}

  {%- if licenses|length > 0 -%}{%- do distribution.update({"license": licenses}) -%}{%- endif -%}

  {#- ---------- personal / sensitive flags ---------- -#}
  {%- set personalData = "unknown" -%}
  {%- if ds.containsPersonalData -%}
    {%- set personalData = "yes" if ds.containsPersonalData._value is sameas true else "no" -%}
  {%- endif -%}
  {%- set sensitiveData = "unknown" -%}
  {%- if ds.containsSensitiveInformation -%}
    {%- set sensitiveData = "yes" if ds.containsSensitiveInformation._value is sameas true else "no" -%}
  {%- endif -%}

  {#- ---------- assemble dataset ---------- -#}
  {%- set dataset = {
    "dataset_id": dsId,
    "title": dsTitle,
    "personal_data": personalData,
    "sensitive_data": sensitiveData,
    "distribution": [distribution]
  } -%}
  {%- if altIds|length > 0      -%}{%- do dataset.update({"alternate_identifier": altIds}) -%}{%- endif -%}
  {%- if dsDescription          -%}{%- do dataset.update({"description": dsDescription}) -%}{%- endif -%}
  {%- if metadataStd|length > 0 -%}{%- do dataset.update({"metadata": metadataStd}) -%}{%- endif -%}
  {%- if qa|length > 0          -%}{%- do dataset.update({"data_quality_assurance": qa}) -%}{%- endif -%}
  {%- do datasets.append(dataset) -%}
{%- endfor -%}


{#- ---------------- Costs (from responsibilities chapter) ---------------- -#}
{%- set costs = [] -%}
{%- if respres.recurringFees and respres.recurringFees._value is sameas true and respres.recurringFees.indicateCosts3 -%}
  {%- do costs.append({"title": "Software licenses / recurring costs",
                       "description": respres.recurringFees.indicateCosts3._value}) -%}
{%- endif -%}
{%- if respres.storageActivePhase and respres.storageActivePhase._value == "yes" and respres.storageActivePhase.indicateCosts2 -%}
  {%- do costs.append({"title": "Active-phase data storage",
                       "description": respres.storageActivePhase.indicateCosts2._value}) -%}
{%- endif -%}
{%- if respres.preservationArchivingAssociated and respres.preservationArchivingAssociated._value == "yes" and respres.preservationArchivingAssociated.indicateCosts -%}
  {%- do costs.append({"title": "Preservation and archiving",
                       "description": respres.preservationArchivingAssociated.indicateCosts._value}) -%}
{%- endif -%}
{%- if respres.hasDataPublicationBudget and respres.hasDataPublicationBudget._value is sameas true and respres.hasDataPublicationBudget.budget -%}
  {%- do costs.append({"title": "Data publication budget",
                       "description": respres.hasDataPublicationBudget.budget._value}) -%}
{%- endif -%}
{%- if respres.totalCostsManagement and respres.totalCostsManagement._value -%}
  {%- do costs.append({"title": "Total data management cost",
                       "description": respres.totalCostsManagement._value}) -%}
{%- endif -%}

{#- ---------------- Assemble top-level dmp object ---------------- -#}
{%- set dmpTitle = (admin.dmpTitle._value if admin.dmpTitle else "") or ctx.project.name -%}

{%- set dmp = {
  "title": dmpTitle,
  "description": madmpDescription,
  "language": "eng",
  "dmp_id": madmpDmpId,
  "contributor": contributors,
  "project": projects,
  "ethical_issues_exist": ethicalIssuesExist,
  "dataset": datasets,
  "created": ctx.project.createdAt|datetime_format("%Y-%m-%dT%H:%M:%SZ"),
  "modified": ctx.project.updatedAt|datetime_format("%Y-%m-%dT%H:%M:%SZ"),
  "cost": costs
} -%}

{%- if contacts|length > 0 -%}
  {%- do dmp.update({"contact": {
    "contact_id": contacts[0]["contributor_id"],
    "mbox": contacts[0]["mbox"],
    "name": contacts[0]["name"]
  }}) -%}
{%- endif -%}

{%- if ethicalIssuesDescription -%}
  {%- do dmp.update({"ethical_issues_description": ethicalIssuesDescription}) -%}
{%- endif -%}

{%- set madmp = {"dmp": dmp} -%}
